from flask import Flask, render_template, request, jsonify
from tinydb import TinyDB, Query
import networkx as nx
import random
import math
import os

app = Flask(__name__)
db = TinyDB('db.json')

# Helper to generate graph
def generate_topology(node_count, area_size, transmission_range):
    # Create a random geometric graph
    # positions are in unit square [0,1], scale to area_size
    # radius is normalized to unit square: range / area_size
    
    radius_normalized = transmission_range / area_size
    # Use seed for reproducibility if needed, but user wants changes on input change
    G = nx.random_geometric_graph(node_count, radius_normalized)
    
    # Add weights (distance)
    for (u, v) in G.edges():
        pos_u = G.nodes[u]['pos']
        pos_v = G.nodes[v]['pos']
        # Euclidean distance scaled to area size
        dist = math.sqrt((pos_u[0] - pos_v[0])**2 + (pos_u[1] - pos_v[1])**2) * area_size
        G.edges[u, v]['weight'] = dist
        # Add random attribute for QoS simulation
        G.edges[u, v]['congestion'] = random.uniform(0.1, 0.9)

    return G

def calculate_metrics(G, path, is_proposed=True):
    if not path:
        return {
            'speed': 0,
            'distance': 0,
            'qos_ratio': 0,
            'priority_delay': 0,
            'service_availability': 0
        }
    
    total_distance = 0
    total_congestion = 0
    
    for i in range(len(path) - 1):
        u, v = path[i], path[i+1]
        if G.has_edge(u, v):
            edge_data = G.edges[u, v]
            total_distance += edge_data['weight']
            total_congestion += edge_data.get('congestion', 0.5)
        else:
            # Estimate distance for non-adjacent nodes
            total_distance += 10.0
            total_congestion += 0.7

    # Simulation Logic for "Proposed should be best"
    # Proposed: Non-Overlapping (implies multi-path or efficient routing, here modeled as optimal shortest path)
    # Existing: Two-Way (modeled as having overheads)

    if is_proposed:
        # Better metrics
        speed_mps = random.uniform(2.5, 4.0) # Faster robot speed
        qos_factor = 0.95 
        delay_overhead = 1.0 # Base delay
        availability_base = 99.0
    else:
        # Worse metrics
        speed_mps = random.uniform(1.0, 2.0) # Slower
        qos_factor = 0.70
        delay_overhead = 1.8 # Higher delay due to "Two Way" handshakes
        availability_base = 85.0

    # Calculate final metrics
    distance_metric = round(total_distance, 2)
    speed_metric = round(speed_mps * (1000 / (total_distance + 1)), 2) # Arbitrary unit
    
    # QoS Satisfaction Ratio (higher is better)
    qos_metric = round(qos_factor * (1 - (total_congestion / len(path))) * 100, 2)
    
    # Priority Packet Delay (lower is better)
    delay_metric = round(total_distance * 0.05 * delay_overhead + random.uniform(5, 15), 2)
    
    # Service Availability (higher is better)
    availability_metric = round(availability_base - (len(path) * 0.5) + random.uniform(0, 2), 2)

    return {
        'speed': speed_metric,
        'distance': distance_metric,
        'qos_ratio': qos_metric,
        'priority_delay': delay_metric,
        'service_availability': availability_metric
    }

@app.route('/')
def index():
    return render_template('home.html', active_page='home')

@app.route('/simulation')
def simulation():
    return render_template('simulation.html', active_page='simulation')

