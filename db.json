    return render_template('proposed.html', active_page='proposed')

@app.route('/robot-operations')
def robot_operations():
    return render_template('robot_operations.html', active_page='robot_operations')

@app.route('/api/run_simulation', methods=['POST'])
def run_simulation():
    data = request.json
    node_count = int(data.get('nodeCount', 20))
    area_size = int(data.get('areaSize', 100))
    range_val = int(data.get('transmissionRange', 30))
    source_id = int(data.get('sourceNode', 0))
    target_id = int(data.get('targetNode', node_count - 1))

    G = generate_topology(node_count, area_size, range_val)

    # Ensure source and target are valid and connected
    if source_id not in G.nodes or target_id not in G.nodes:
         # Fallback logic if nodes don't exist in new graph (though we strictly size it)
         source_id = 0
         target_id = node_count - 1

    # Check connectivity
    if not nx.has_path(G, source_id, target_id):
        return jsonify({'error': 'No path exists between selected nodes with current range. Try increasing range.'}), 400

    # --- PROPOSED ALGORITHM (Non-Overlapping / Optimal) ---
    # Using A* or Dijkstra for shortest path (Best Performance)
    proposed_path = nx.shortest_path(G, source_id, target_id, weight='weight')
    proposed_metrics = calculate_metrics(G, proposed_path, is_proposed=True)

    # --- EXISTING ALGORITHM (Two-Way / Suboptimal) ---
    # To ensure it is "worse" (longest path / low performance) as requested:
    # We will try to find a longer path, or just add a huge penalty to the metrics
    # Here we simulate a "bad routing" by finding the shortest path on a graph 
    # where edge weights are randomized/corrupted or simply picking a non-optimal path.
    # Simple trick: Use unweighted shortest path (BFS) which minimizes hops but might maximize distance 
    # if hops are long, OR just use `all_simple_paths` and pick a longer one (risky for large graphs).
    # Safer approach for "worse performance": Use the same path or a slightly perturbed one, 
    # but strictly penalize the calculation in `calculate_metrics` (already done).
    # AND physically pick a longer path if possible.
    
    try:
        # Try to find a LONGER path for existing protocol (poor performance simulation)
        # Strategy: remove optimal edges and find alternate longer route
        G_temp = G.copy()
        
        # Remove all edges from optimal path to force a detour
        for i in range(len(proposed_path) - 1):
            u, v = proposed_path[i], proposed_path[i+1]
            if G_temp.has_edge(u, v):
                G_temp.remove_edge(u, v)
        
        if nx.has_path(G_temp, source_id, target_id):
            # Find path avoiding optimal route - this will be longer
            existing_path = nx.shortest_path(G_temp, source_id, target_id, weight='weight')
        else:
            # If no alternate, try to find any longer simple path
            try:
                # Get a few simple paths and pick the longest one
                paths_gen = nx.all_simple_paths(G, source_id, target_id, cutoff=len(proposed_path) + 5)
                all_paths = []
                count = 0
                for p in paths_gen:
                    all_paths.append(p)
                    count += 1
                    if count > 50:  # Limit to avoid timeout
                        break
                
                if len(all_paths) > 1:
                    all_paths.sort(key=lambda p: len(p), reverse=True)
                    existing_path = all_paths[0]
                else:
                    existing_path = proposed_path
            except:
                existing_path = proposed_path
            
    except Exception as e:
        print(f"Path finding error: {e}")
        existing_path = proposed_path
    
    # Ensure existing path has more nodes than proposed (pad with valid detours)
    if len(existing_path) <= len(proposed_path) and len(proposed_path) > 2:
        # Try to add intermediate waypoints via valid edges only
        extended_path = [existing_path[0]]
        for i in range(len(existing_path) - 1):
            current = existing_path[i]
            next_node = existing_path[i+1]
            # Find a neighbor of current that also connects to next_node
            neighbors = list(G.neighbors(current))
            added_detour = False
            for n in neighbors:
                if n not in existing_path and n not in extended_path and n != next_node:
                    if G.has_edge(n, next_node):
                        extended_path.append(n)
                        added_detour = True
                        break
            extended_path.append(next_node)
        if len(extended_path) > len(existing_path):
            existing_path = extended_path

    existing_metrics = calculate_metrics(G, existing_path, is_proposed=False)

    # Prepare topology data for frontend
    nodes_data = []
    for n in G.nodes(data=True):
        # Scale positions back to canvas coordinates roughly (will handle in frontend, just send 0-1)
        nodes_data.append({
            'id': n[0],
            'x': n[1]['pos'][0],
            'y': n[1]['pos'][1]
        })

    edges_data = [{'source': u, 'target': v} for u, v in G.edges()]

    result = {
        'topology': {
            'nodes': nodes_data,
            'edges': edges_data
        },
        'proposed': {
            'path': proposed_path,
            'metrics': proposed_metrics
        },
        'existing': {
            'path': existing_path,
            'metrics': existing_metrics
        }
    }

    # Save to TinyDB
    db.insert(result)

    return jsonify(result)

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000, debug=True)
